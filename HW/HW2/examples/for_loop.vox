// for 循环示例
func factorial(n: int) -> int {
    var result: int = 1;
    for (var i: int = 2; i <= n; i = i + 1) {
        result = result * i;
    }
    return result;
}

print(factorial(5));
print(factorial(10));

// for 循环中的 break 和 continue
for (var i: int = 0; i < 10; i = i + 1) {
    if (i == 3) {
        continue;
    }
    if (i == 7) {
        break;
    }
    print(i);
}